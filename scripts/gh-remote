#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$REPO_ROOT/.env"

log_error() {
  local message="$1"
  printf '[gh-remote] %s\n' "$message" >&2
}

if [[ ! -f "$ENV_FILE" ]]; then
  log_error "Run scripts/setup-remote-env first to generate .env."
  exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
  log_error "gh command is required."
  exit 1
fi

set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a

exec gh "$@"
